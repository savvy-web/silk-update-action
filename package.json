{
	"name": "silk-update-action",
	"version": "3.0.1",
	"private": true,
	"description": "GitHub Action for updating pnpm config dependencies and regular dependencies with automated PR creation",
	"keywords": ["github-action", "pnpm", "config-dependencies", "dependency-updates", "monorepo", "changesets"],
	"homepage": "https://github.com/savvy-web/silk-update-action#readme",
	"bugs": {
		"url": "https://github.com/savvy-web/silk-update-action/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/silk-update-action.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"scripts": {
		"build": "turbo run build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"build:prod": "github-action-builder build",
		"ci:build": "CI=\"true\" turbo run build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run --coverage",
		"ci:version": "savvy changeset version && biome format --write .",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run --pass-with-no-tests",
		"test:coverage": "vitest run --coverage --pass-with-no-tests",
		"test:watch": "vitest --watch --pass-with-no-tests",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit",
		"validate": "github-action-builder validate"
	},
	"dependencies": {
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@pnpm/lockfile.fs": "^1100.1.3",
		"@pnpm/lockfile.types": "^1100.0.9",
		"@savvy-web/github-action-effects": "^2.1.4",
		"@savvy-web/silk-effects": "^1.0.1",
		"effect": "catalog:silk",
		"runtime-resolver": "^0.3.12",
		"semver-effect": "^0.2.1",
		"workspaces-effect": "^1.2.0",
		"yaml": "^2.9.0"
	},
	"devDependencies": {
		"@savvy-web/github-action-builder": "^0.7.7",
		"@savvy-web/silk": "^0.4.2",
		"@savvy-web/vitest": "^1.5.0"
	},
	"packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
	"engines": {
		"node": ">=24.0.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.3.0",
				"onFail": "ignore"
			}
		]
	}
}
